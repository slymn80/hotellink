# ============================================================
# HotelLink Environment Variables
# Copy this file to .env.local and fill in all values
# ============================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=HotelLink
NODE_ENV=development

# Database (PostgreSQL via Supabase or local)
DATABASE_URL="postgresql://postgres:1234@localhost:5432/hotellink?schema=public"
DIRECT_URL="postgresql://postgres:1234@localhost:5432/hotellink?schema=public"

# NextAuth / Auth.js
AUTH_SECRET="your-super-secret-key-minimum-32-chars"
AUTH_URL=http://localhost:3000

# OAuth Providers (optional)
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret
AUTH_LINKEDIN_ID=your-linkedin-client-id
AUTH_LINKEDIN_SECRET=your-linkedin-client-secret

# Supabase (for file storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stripe (payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs
STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
STRIPE_STARTER_ANNUAL_PRICE_ID=price_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_...
STRIPE_ENTERPRISE_ANNUAL_PRICE_ID=price_...

# Email (Resend or SendGrid)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@hotellink.com

# Redis (for rate limiting and sessions)
REDIS_URL=redis://localhost:6379

# Upstash Redis (serverless)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry (error monitoring)
SENTRY_DSN=https://...
NEXT_PUBLIC_SENTRY_DSN=https://...

# Admin
ADMIN_EMAIL=admin@hotellink.com
